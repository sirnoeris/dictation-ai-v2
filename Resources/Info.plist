<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- App identity -->
    <key>CFBundleName</key>
    <string>DictationAI</string>
    <key>CFBundleDisplayName</key>
    <string>Dictation AI</string>
    <key>CFBundleIdentifier</key>
    <string>com.sirnoeris.DictationAI</string>
    <key>CFBundleVersion</key>
    <string>2</string>
    <key>CFBundleShortVersionString</key>
    <string>2.0.0</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <!-- Menu-bar only — suppresses Dock icon and App Switcher entry -->
    <key>LSUIElement</key>
    <true/>

    <!-- macOS minimum version -->
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>

    <!-- Privacy usage strings (required for Mac App Store / notarisation) -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Dictation AI needs microphone access to record your voice.</string>

    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Dictation AI uses on-device speech recognition to preview your dictation.</string>

    <!-- Accessibility note: shown in System Settings → Privacy → Accessibility -->
    <key>NSAppleEventsUsageDescription</key>
    <string>Dictation AI needs Accessibility access to paste transcribed text at your cursor.</string>

    <!-- Single-instance enforcement -->
    <key>LSMultipleInstancesProhibited</key>
    <true/>

    <!-- App icon -->
    <key>CFBundleIconName</key>
    <string>AppIcon</string>

</dict>
</plist>
