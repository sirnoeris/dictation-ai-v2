<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime: required for notarisation / Gatekeeper -->
    <key>com.apple.security.app-sandbox</key>
    <false/>  <!-- Disabled: CGEventTap requires running outside the sandbox -->

    <key>com.apple.security.device.audio-input</key>
    <true/>   <!-- Microphone access -->

    <key>com.apple.security.network.client</key>
    <true/>   <!-- xAI / WhisperKit model download -->

    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>   <!-- Temp audio file writes -->

    <!-- Hardened Runtime exceptions needed for CGEventTap and WhisperKit CoreML -->
    <key>com.apple.security.cs.allow-jit</key>
    <false/>

    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>  <!-- Required for WhisperKit's CoreML models -->
</dict>
</plist>
